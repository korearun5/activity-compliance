# Local Docker defaults. Change all secrets before sharing an environment.
SPRING_PROFILES_ACTIVE=local

# Host port used when publishing the Docker PostgreSQL container.
# The backend container still reaches PostgreSQL at postgres:5432.
APP_POSTGRES_PORT=55432

APP_DB_URL=jdbc:postgresql://postgres:5432/activity_platform
APP_DB_USERNAME=activity_app
APP_DB_PASSWORD=activity_app

APP_JWT_SECRET=docker-development-jwt-secret-change-before-any-shared-env
APP_CORS_ALLOWED_ORIGIN_WEB=http://localhost:19006

APP_STORAGE_PROVIDER=minio
MINIO_IMAGE=minio/minio:latest
APP_MINIO_ENDPOINT=http://minio:9000
APP_MINIO_BUCKET=activity-platform
APP_MINIO_ACCESS_KEY=activity_minio
APP_MINIO_SECRET_KEY=activity_minio_password
APP_MINIO_SECURE=false
APP_MINIO_CREATE_BUCKET_IF_MISSING=true

EXPO_PUBLIC_APP_NAME=Activity Compliance
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_API_VERSION=v1
EXPO_PUBLIC_DEFAULT_TENANT_CODE=default
EXPO_PUBLIC_DEFAULT_LOCALE=en-IN
EXPO_PUBLIC_STORAGE_NAMESPACE=activity-platform
