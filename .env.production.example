# Production example. Copy values into your secret manager or deployment
# platform; do not commit real credentials.
SPRING_PROFILES_ACTIVE=prod

APP_DB_URL=jdbc:postgresql://db.example.com:5432/activity_platform
APP_DB_USERNAME=activity_app
APP_DB_PASSWORD=<strong-database-password>

APP_JWT_ISSUER=activity-compliance-prod
APP_JWT_SECRET=<at-least-48-characters-random-secret>
APP_ACCESS_TOKEN_TTL=PT30M
APP_REFRESH_TOKEN_TTL=P7D

APP_CORS_ALLOWED_ORIGINS=https://app.example.com
APP_CORS_ALLOW_CREDENTIALS=false

APP_STORAGE_PROVIDER=minio
APP_MAX_UPLOAD_BYTES=10485760
APP_MINIO_ENDPOINT=https://minio.example.com
APP_MINIO_BUCKET=activity-platform
APP_MINIO_ACCESS_KEY=<minio-access-key>
APP_MINIO_SECRET_KEY=<minio-secret-key>
APP_MINIO_REGION=us-east-1
APP_MINIO_SECURE=true
APP_MINIO_CREATE_BUCKET_IF_MISSING=false

APP_PORT=8080
APP_LOG_LEVEL_ROOT=WARN
APP_LOG_LEVEL_APP=INFO
APP_LOG_LEVEL_SECURITY=WARN
APP_OPENAPI_ENABLED=false
APP_SWAGGER_UI_ENABLED=false
APP_SEED_ENABLED=false

EXPO_PUBLIC_APP_NAME=Activity Compliance
EXPO_PUBLIC_API_BASE_URL=https://api.example.com
EXPO_PUBLIC_API_VERSION=v1
EXPO_PUBLIC_DEFAULT_TENANT_CODE=default
EXPO_PUBLIC_DEFAULT_LOCALE=en-IN
EXPO_PUBLIC_STORAGE_NAMESPACE=activity-platform
EXPO_PUBLIC_ENABLED_CLIENT_MODULES=carbon
